<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Highly Arcade</title>

<style>
body {
  background:#06070f;
  color:white;
  font-family:sans-serif;
  margin:0;
}

/* NAV */
nav {
  padding:12px 16px;
  border-bottom:1px solid rgba(255,255,255,0.1);
  font-weight:bold;
}

/* GRID */
.game-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(120px,1fr));
  gap:10px;
  padding:15px;
}

.game-btn {
  background:#111;
  padding:15px;
  border-radius:12px;
  text-align:center;
  cursor:pointer;
}

.game-btn.active {
  background:#7c3aed;
}

/* GAME AREA */
.game-area {
  display:none;
  padding:15px;
}
.game-area.active {
  display:block;
}

/* CANVAS */
canvas {
  max-width:100%;
  display:block;
  margin:auto;
  border-radius:10px;
  border:2px solid #222;
}

/* MOBILE CONTROLS */
.controls {
  display:flex;
  justify-content:center;
  gap:10px;
  margin-top:10px;
}

.controls button {
  padding:10px;
  border:none;
  border-radius:8px;
  background:#222;
  color:white;
}

/* 2048 */
.board {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:6px;
  max-width:300px;
  margin:auto;
}
.cell {
  aspect-ratio:1;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#222;
  border-radius:6px;
  font-weight:bold;
}

/* BLOCK */
#blockBoard {
  display:grid;
  grid-template-columns:repeat(10,1fr);
  gap:4px;
  max-width:320px;
  margin:auto;
}
.block {
  aspect-ratio:1;
  background:#222;
  border-radius:4px;
}
.block.f {
  background:#a855f7;
}
</style>
</head>

<body>

<nav>🎮 Highly Arcade</nav>

<div class="game-grid">
  <div class="game-btn active" data="snake">🐍 Snake</div>
  <div class="game-btn" data="g2048">🔢 2048</div>
  <div class="game-btn" data="block">🧱 Block</div>
</div>

<!-- SNAKE -->
<div id="snake" class="game-area active">
  <button onclick="startSnake()">Başlat</button>
  <canvas id="snakeC" width="300" height="300"></canvas>

  <div class="controls">
    <button onclick="setDir(0,-1)">↑</button>
    <button onclick="setDir(-1,0)">←</button>
    <button onclick="setDir(1,0)">→</button>
    <button onclick="setDir(0,1)">↓</button>
  </div>
</div>

<!-- 2048 -->
<div id="g2048" class="game-area">
  <button onclick="init2048()">Yenile</button>
  <div id="board" class="board"></div>
</div>

<!-- BLOCK -->
<div id="block" class="game-area">
  <button onclick="initBlock()">Başlat</button>
  <div id="blockBoard"></div>
</div>

<script>

/* TAB */
document.querySelectorAll(".game-btn").forEach(btn=>{
  btn.onclick=()=>{
    document.querySelectorAll(".game-btn").forEach(b=>b.classList.remove("active"));
    document.querySelectorAll(".game-area").forEach(g=>g.classList.remove("active"));
    btn.classList.add("active");
    document.getElementById(btn.getAttribute("data")).classList.add("active");
  }
});

/* ================= SNAKE ================= */
let snake,dir,food,loop;

function startSnake(){
  snake=[[5,5]];
  dir={x:1,y:0};
  food={x:10,y:10};

  clearInterval(loop);
  loop=setInterval(updateSnake,150);
}

function setDir(x,y){
  dir={x,y};
}

function updateSnake(){
  let head=[snake[0][0]+dir.x, snake[0][1]+dir.y];

  if(head[0]<0||head[1]<0||head[0]>19||head[1]>19){
    clearInterval(loop);
    alert("bitti");
    return;
  }

  snake.unshift(head);

  if(head[0]==food.x && head[1]==food.y){
    food={x:Math.floor(Math.random()*20),y:Math.floor(Math.random()*20)};
  } else {
    snake.pop();
  }

  drawSnake();
}

function drawSnake(){
  let c=document.getElementById("snakeC");
  let ctx=c.getContext("2d");

  ctx.fillStyle="#000";
  ctx.fillRect(0,0,300,300);

  snake.forEach(s=>{
    ctx.fillStyle="#a855f7";
    ctx.fillRect(s[0]*15,s[1]*15,14,14);
  });

  ctx.fillStyle="red";
  ctx.fillRect(food.x*15,food.y*15,14,14);
}

/* ================= 2048 ================= */
let b;

function init2048(){
  b=Array(4).fill(0).map(()=>Array(4).fill(0));
  add(); add();
  draw2048();
}

function add(){
  let empty=[];
  b.forEach((r,i)=>r.forEach((v,j)=>{if(!v)empty.push([i,j])}));
  if(!empty.length)return;
  let [r,c]=empty[Math.floor(Math.random()*empty.length)];
  b[r][c]=2;
}

function draw2048(){
  let el=document.getElementById("board");
  el.innerHTML="";
  b.flat().forEach(v=>{
    let d=document.createElement("div");
    d.className="cell";
    d.textContent=v||"";
    el.appendChild(d);
  });
}

function move(dir){
  // basit (upgrade edilebilir)
}

/* SWIPE */
let sx,sy;
document.addEventListener("touchstart",e=>{
  sx=e.touches[0].clientX;
  sy=e.touches[0].clientY;
});

document.addEventListener("touchend",e=>{
  let dx=e.changedTouches[0].clientX-sx;
  let dy=e.changedTouches[0].clientY-sy;

  if(Math.abs(dx)>Math.abs(dy)){
    if(dx>30) move("right");
    else move("left");
  } else {
    if(dy>30) move("down");
    else move("up");
  }
});

/* ================= BLOCK ================= */
let grid;

function initBlock(){
  grid=Array(10).fill(0).map(()=>Array(10).fill(0));
  drawBlock();
}

function drawBlock(){
  let el=document.getElementById("blockBoard");
  el.innerHTML="";

  grid.forEach((r,i)=>{
    r.forEach((v,j)=>{
      let d=document.createElement("div");
      d.className="block"+(v?" f":"");
      d.onclick=()=>{
        grid[i][j]=1;
        drawBlock();
      };
      el.appendChild(d);
    });
  });
}

</script>

</body>
</html>
